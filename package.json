{
  "name": "driftking-client",
  "version": "1.0.0",
  "description": "Custom desktop client for Drift King with region switcher",
  "author": "andronedev",
  "license": "MIT",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder --mac --win",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "dev.androne.driftking",
    "productName": "Drift King",
    "files": [
      "main.js",
      "frontend/**/*"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.games"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "devDependencies": {
    "electron": "^35",
    "electron-builder": "^26"
  }
}
